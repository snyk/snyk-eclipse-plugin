sequenceDiagram
    autonumber
    participant U as User
    participant JS as tree.js
    participant W as window.__ideExecuteCommand__<br/>(injected wrapper)
    participant BF as __ideExecuteCommandBridge__<br/>(SWT BrowserFunction)
    participant CH as CommandHandler
    participant LS as Language Server

    U->>JS: click vulnerability node
    JS->>W: window.__ideExecuteCommand__("snyk.navigateToRange", [path, range], cb)
    W->>BF: __ideExecuteCommandBridge__(cmd, JSON.stringify(args), callbackId)
    BF->>CH: executeCommand("snyk.navigateToRange", args)
    CH->>LS: workspace/executeCommand
    LS-->>CH: result (Object | null)
    CH-->>BF: CompletableFuture completes
    BF->>BF: build JS: window.__ideCallbacks__[id](result)
    BF->>W: browser.evaluate(script)  [Display.asyncExec]
    W->>JS: invoke callback(result)
